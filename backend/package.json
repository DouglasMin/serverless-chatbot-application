{
  "name": "@chatbot/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rimraf src/lambda/* && npx tsc && npx slsberry",
    "deploy": "rimraf src/lambda/* && npx tsc && npx slsberry && npx sls deploy --verbose",
    "doc": "rimraf src/lambda/* && npx tsc && npx slsberry --openapi"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@middy/core": "^7.1.5",
    "@middy/http-error-handler": "^7.1.5",
    "@middy/http-json-body-parser": "^7.1.5",
    "@middy/util": "^7.1.5",
    "@middy/validator": "^7.1.5",
    "json-schema-to-ts": "^3.1.1",
    "layerr": "^3.0.0",
    "openai": "^5.19.0",
    "ulidx": "^2.4.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "esbuild": "^0.27.4",
    "rimraf": "^6.1.3",
    "serverless": "^3.40.0",
    "serverless-cloudformation-sub-variables": "^0.2.1",
    "serverless-deployment-bucket": "^1.6.0",
    "serverless-esbuild": "^1.57.0",
    "slsberry": "^0.0.71",
    "typescript": "^5.7.0"
  }
}
